# NOBD MvC2 Oracle bot — runtime secrets/config for the VPS.
# Copied to /opt/nobd-oracle/oracle-bot/discord-bot/.env by deploy.sh, then YOU fill the secrets.
# chmod 600. NEVER commit (the real .env is gitignored). systemd loads this via EnvironmentFile.
# Bare KEY=value lines (no quotes, no `export`).

DISCORD_BOT_TOKEN=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
# Channels the bot answers in (general, oracle, why-nobd, re-and-tech, mvc2):
ORACLE_CHANNEL_ID=1519435081176059978,1519454747063615528,1519424080271507496,1519424105215033344,1519424095941562519
# Chat-box mode (1) needs the Message Content Intent (it's enabled). Set 0 for mention-only.
ORACLE_MESSAGE_CONTENT=1
