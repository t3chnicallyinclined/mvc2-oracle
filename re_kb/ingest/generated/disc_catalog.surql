USE NS re DB kb;

UPSERT source:disc_mvc2_devfiles SET kind='disc', ref='MVC2 Dev Files/', note='MVC2 Dreamcast disc \'Dev Files\' dump — 866 .BIN files, 24 families, 152 MB. RE catalog only (file inventory, not ROM bytes).';
UPSERT source:pldat_decoded SET kind='pldat', ref='dasm_PLDAT/Output/', note='PLDAT decoded structure (dasm_PLDAT_v005a.py) — 60 PLxx_DAT dirs, 60 palette dumps. Format catalog (GFX1/GFX2/PALETTE/ANIM/EXTRAS/HITBOX/ATTACK).';

UPSERT region:disc_devfiles SET name='disc_devfiles', note='MVC2 disc Dev Files: 866 .BIN files in 24 families (PLx292, ATCKx59, HITx59, HIT_DTx59, HIT_FMx59, LIBx59, TAIKIx59, WARIx59, YOKx59, DMx34, STGx34, ADX_Sx13). RE inventory; not ROM bytes.';
RELATE region:disc_devfiles->cites->source:disc_mvc2_devfiles;

