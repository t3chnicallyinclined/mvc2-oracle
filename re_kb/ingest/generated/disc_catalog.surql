UPSERT dataformat:pldat_header SET name='pldat_header', kind='pldat', note='PLxx_DAT.BIN top-level pointer table: 0x00=gfx_pointer01 -> GFX1 part-pixel block (Dat_GFX1; decoded sprite parts); 0x04=gfx_pointer02 -> GFX2 block (Dat_GFX2; secondary parts/cells); 0x08=palette_pointer -> PALETTE block (ARGB4444, 16-color rows, idx0=transparent); 0x0C=extras_pointer -> EXTRAS / sprite-assembly (OAM) table; 0x10=separation_blank padding/separator; 0x14=animations -> ANIMATION_DATA (per-frame durations + EXTRAS ptr table); 0x18=hitbox_pattern_table -> hitbox pattern table; 0x1C=hitbox_data -> hitbox data; 0x20=attack_data -> attack data; 0x24=ai_script_00 -> AI script 0; 0x28=ai_script_01 -> AI script 1; 0x2C=ai_script_02 -> AI script 2; 0x30=ai_script_03 -> AI scripts (likely); 0x34=ai_script_04 -> AI script 3; 0x38=separation_blank padding/separator; 0x3C=separation_blank padding/separator';
RELATE dataformat:pldat_header->cites->source:pldat_decoded;

UPSERT dataformat:pldat_gfx1 SET name='GFX1', kind='pldat_section', char_count=60, note='PLDAT GFX1 section (GFX_DATA_00): u32 LE offset table -> variable-length 4bpp sprite PARTS (piece header [w_tiles][h_tiles][padded_w][padded_h]; transparency-aware 4bpp stream; idx0=transparent). ~1533 pieces in PL00. RLE control codec still unsolved. Decoded for 60 chars.';
RELATE dataformat:pldat_gfx1->cites->source:pldat_decoded;
UPSERT dataformat:pldat_gfx2 SET name='GFX2', kind='pldat_section', char_count=60, note='PLDAT GFX2 section (GFX_DATA_01): secondary GFX block (additional parts/cells); same offset-table + 4bpp part encoding as GFX1. Decoded for 60 chars.';
RELATE dataformat:pldat_gfx2->cites->source:pldat_decoded;
UPSERT dataformat:pldat_palette SET name='PALETTE', kind='pldat_section', char_count=60, note='PLDAT PALETTE section (PALETTE_DATA): palette table: N rows x 16 colors x 2B ARGB4444 LE, idx0=transparent (PL00 = 57 palettes / 1824 B). Same banks as the PVR skin system. Decoded for 60 chars.';
RELATE dataformat:pldat_palette->cites->source:pldat_decoded;
UPSERT dataformat:pldat_animation SET name='ANIMATION', kind='pldat_section', char_count=60, note='PLDAT ANIMATION section (ANIMATION_DATA): 0x000-0x3FF header w/ per-frame durations (03E8=1000); 0x400+ = u32 LE pointer table into EXTRAS (random-access frame index). Decoded for 60 chars.';
RELATE dataformat:pldat_animation->cites->source:pldat_decoded;
UPSERT dataformat:pldat_extras SET name='EXTRAS', kind='pldat_section', char_count=60, note='PLDAT EXTRAS section (EXTRAS_DATA): sprite-assembly / OAM table: 8-byte records [x:s16][y:s16][tile:u16][attr:u16]; attr=0x00FF = frame terminator; attr bit15=h-flip; low byte = palette row. PL00 = 31 frames, 12-147 parts each. Decoded for 60 chars.';
RELATE dataformat:pldat_extras->cites->source:pldat_decoded;
UPSERT dataformat:pldat_hitbox SET name='HITBOX', kind='pldat_section', char_count=60, note='PLDAT HITBOX section (HITBOX_DATA): hitbox data + HITBOX_PATTERN_TABLE; frame-accurate collision boxes. Decoded for 60 chars.';
RELATE dataformat:pldat_hitbox->cites->source:pldat_decoded;
UPSERT dataformat:pldat_attack SET name='ATTACK', kind='pldat_section', char_count=60, note='PLDAT ATTACK section (ATTACK_DATA): per-frame attack / damage / properties data. Decoded for 60 chars.';
RELATE dataformat:pldat_attack->cites->source:pldat_decoded;
UPSERT dataformat:pldat_ai_script SET name='AI_SCRIPT', kind='pldat_section', char_count=60, note='PLDAT AI_SCRIPT section (AI_SCRIPT_DATA_00..04): AI behaviour scripts (5 slots per character). Decoded for 60 chars.';
RELATE dataformat:pldat_ai_script->cites->source:pldat_decoded;
RELATE dataformat:pldat_gfx1->maps_to->field:dat_gfx1;
RELATE dataformat:pldat_gfx2->maps_to->field:dat_gfx2;
RELATE dataformat:pldat_palette->maps_to->field:dat_pal;
RELATE finding:part_decode_mechanism->about->dataformat:pldat_gfx1;
